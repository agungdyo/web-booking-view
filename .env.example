# Environment Variables

# API Base URL
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Default Tenant Code (required for this booking app)
# This is the tenant identifier for accessing the booking system
# Example: MAJU1234
VITE_DEFAULT_TENANT=MAJU1234

